{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "VitePress Preview",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/vitepress", "dev", "docs"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "VitePress Dev",
      "runtimeExecutable": "/opt/homebrew/bin/npm",
      "runtimeArgs": ["run", "docs:dev"],
      "port": 5173,
      "autoPort": true
    }
  ]
}
